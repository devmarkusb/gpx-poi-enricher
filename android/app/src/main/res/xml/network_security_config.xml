<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- OSRM public demo server only supports HTTP; allow cleartext for that host only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">router.project-osrm.org</domain>
    </domain-config>
</network-security-config>
